---
import '../../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ingressus Solutions</title>
  </head>

  <body class="bg-slate-950 text-white overflow-x-hidden">
    <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden">
      <svg
        data-lines
        class="absolute inset-0 h-full w-full opacity-50"
        viewBox="0 0 1920 1080"
        preserveAspectRatio="none"
      >
        {Array.from({ length: 18 }).map((_, i) => (
          <path
            d={`M-200 ${260 + i * 34} C 250 ${80 + i * 18}, 520 ${620 - i * 10}, 900 ${420 + i * 16} S 1450 ${160 + i * 24}, 2120 ${360 + i * 22}`}
            stroke={i % 2 === 0 ? '#00d4ff' : '#a855f7'}
            stroke-width={i % 3 === 0 ? '1.4' : '0.8'}
            fill="none"
            opacity={0.18 + i * 0.018}
          />
        ))}

        {Array.from({ length: 14 }).map((_, i) => (
          <path
            d={`M${300 + i * 70} -120 C ${120 + i * 40} 220, ${760 - i * 20} 420, ${520 + i * 80} 760 S ${900 + i * 60} 1180, ${1220 + i * 45} 1220`}
            stroke={i % 2 === 0 ? '#38bdf8' : '#7c3aed'}
            stroke-width="0.8"
            fill="none"
            opacity="0.22"
          />
        ))}

        <circle cx="420" cy="640" r="2" fill="#22d3ee" opacity="0.9" />
        <circle cx="1280" cy="260" r="2" fill="#a855f7" opacity="0.9" />
        <circle cx="1560" cy="720" r="2" fill="#22d3ee" opacity="0.7" />
      </svg>
    </div>

    <main class="relative z-10 min-h-screen">
      <div class="absolute right-6 top-8 z-50 flex gap-3 text-sm">
        <a href="/" class="text-cyan-400 hover:text-cyan-300">
          HU
        </a>

        <span class="text-slate-600">|</span>

        <a href="/en" class="text-cyan-400 hover:text-cyan-300">
          EN
        </a>
      </div>

      <section class="mx-auto flex min-h-screen max-w-6xl flex-col justify-center px-6 py-20 pt-46">
        <div class="absolute left-1/2 top-10 -translate-x-1/2">
          <img
            src="/logo.png"
            alt="Ingressus Solutions"
            class="h-16 w-auto opacity-80 md:h-20"
          />
        </div>

        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-cyan-400">
          Automation • Cloud • AI
        </p>

        <h1 class="max-w-4xl text-5xl font-bold tracking-tight md:text-7xl">
          Less time.
          <br />
          More efficient operations.
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
          We help automate repetitive tasks, connect your systems,
          and build cloud-based solutions that save you time and money.
        </p>

        <p class="mt-6 max-w-2xl text-lg font-medium text-cyan-300">
          You don't need to carry the cost of a full-time employee.
          <br />
          Our flexible pricing ensures you only pay for what you need.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="#contact"
            class="rounded-full bg-cyan-400 px-6 py-3 text-center font-semibold text-slate-950 transition hover:bg-cyan-300"
          >
            Contact Us
          </a>

          <a
            href="#services"
            class="rounded-full border border-slate-700 px-6 py-3 text-center font-semibold text-white transition hover:border-cyan-400"
          >
            Services
          </a>
        </div>
      </section>

      <section id="services" class="mx-auto max-w-6xl px-6 py-20">
        <h2 class="text-3xl font-bold md:text-4xl">Services</h2>

        <div class="mt-10 grid gap-6 md:grid-cols-3">
          <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
            <h3 class="text-xl font-semibold">
              Business Process Automation
            </h3>

            <div class="mt-3 h-[2px] w-32 rounded-full bg-gradient-to-r from-cyan-400 to-violet-500"></div>

            <p class="mt-4 text-slate-300">
              Custom automation for reports, spreadsheets and repetitive workflows,
              reducing manual effort while improving efficiency and speed.

              <br />
              <br />

              Let your business operate more efficiently.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
            <h3 class="text-xl font-semibold">Cloud Solutions</h3>

            <div class="mt-3 h-[2px] w-32 rounded-full bg-gradient-to-r from-cyan-400 to-violet-500"></div>

            <p class="mt-4 text-slate-300">
              Design, development and operation of modern cloud-native systems on AWS and Google Cloud.
              Automated infrastructure, monitoring, data processing and scalable architectures.

              <br />
              <br />

              Kubernetes, Infrastructure as Code (IaC), Docker, CI/CD and version control solutions
              that make development and operations faster, safer and more efficient.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
            <h3 class="text-xl font-semibold">Practical AI Solutions</h3>

            <div class="mt-3 h-[2px] w-32 rounded-full bg-gradient-to-r from-cyan-400 to-violet-500"></div>

            <p class="mt-4 text-slate-300">
              Document search chatbots, internal knowledge bases, AI assistants
              and custom AI solutions designed to optimize daily workflows.

              <br />
              <br />

              We also help with AI adoption, employee training and establishing
              effective AI usage practices, ensuring the technology delivers
              real business value.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
            <h3 class="text-xl font-semibold">Lead Capture for Events</h3>

            <div class="mt-3 h-[2px] w-32 rounded-full bg-gradient-to-r from-cyan-400 to-violet-500"></div>

            <p class="mt-4 text-slate-300">
              Tired of business cards and manually collecting contact details?
              We have a better solution!

              <br />
              <br />

              QR-based networking, instant contact exchange and digital business cards.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
            <h3 class="text-xl font-semibold">Landing Pages & Portfolio Websites</h3>

            <div class="mt-3 h-[2px] w-32 rounded-full bg-gradient-to-r from-cyan-400 to-violet-500"></div>

            <p class="mt-4 text-slate-300">
              Need a simple portfolio website or landing page?
              We've got you covered.
            </p>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-6xl px-6 py-20">
        <h2 class="text-3xl font-bold md:text-4xl">Featured Projects</h2>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
            <h3 class="text-xl font-semibold">QuentryX</h3>

            <p class="mt-4 text-slate-300">
              A proprietary event management platform currently under active development.
              Designed to simplify digital ticketing, QR-based access control
              and event administration.
            </p>

            <span class="mt-6 inline-block rounded-full bg-amber-500/20 px-3 py-1 text-sm font-medium text-amber-300">
              In Development
            </span>
          </div>

          <div class="rounded-3xl border border-slate-800 bg-slate-900/60 p-6">
            <h3 class="text-xl font-semibold">QR Lead Capture</h3>

            <p class="mt-4 text-slate-300">
              A QR-based networking solution for conferences and business events,
              allowing you to collect leads quickly and efficiently.
            </p>

            <a
              href="https://www.qrleadcapture.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex font-semibold text-cyan-400 transition hover:text-cyan-300"
            >
              Visit QR Lead Capture →
            </a>
          </div>
        </div>
      </section>

      <section id="contact" class="mx-auto max-w-6xl px-6 py-20">
        <div class="rounded-3xl border border-cyan-400/30 bg-cyan-400/10 p-8">
          <h2 class="text-center text-3xl font-bold">
            Do you have a repetitive task that could be automated?
          </h2>

          <p class="mx-auto mt-4 max-w-2xl text-center text-slate-300">
            Tell us briefly what you need help with and we'll get back to you.
          </p>

          <form
            action="https://formspree.io/f/xgobkodq"
            method="POST"
            class="mx-auto mt-10 max-w-2xl space-y-4"
          >
            <input
              type="hidden"
              name="_subject"
              value="[Ingressus Solutions] New contact form submission"
            />

            <input
              type="text"
              name="_gotcha"
              style="display:none"
            />

            <input
              type="text"
              name="name"
              placeholder="Your Name"
              required
              class="w-full rounded-xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-white placeholder-slate-400 focus:border-cyan-400 focus:outline-none"
            />

            <input
              type="email"
              name="email"
              placeholder="Your Email"
              required
              class="w-full rounded-xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-white placeholder-slate-400 focus:border-cyan-400 focus:outline-none"
            />

            <textarea
              name="message"
              rows="5"
              placeholder="Briefly describe how we can help..."
              required
              class="w-full rounded-xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-white placeholder-slate-400 focus:border-cyan-400 focus:outline-none"
            ></textarea>

            <button
              type="submit"
              class="w-full rounded-xl bg-cyan-400 px-6 py-3 font-semibold text-slate-950 transition hover:bg-cyan-300"
            >
              Send Message
            </button>
          </form>
        </div>
      </section>
    </main>

    <script>
      const lines = document.querySelector('[data-lines]');

      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;

        if (lines instanceof HTMLElement || lines instanceof SVGElement) {
          lines.style.transform = `
            translateY(${scrollY * -0.08}px)
            translateX(${Math.sin(scrollY * 0.002) * 24}px)
            rotate(${Math.sin(scrollY * 0.001) * 1.5}deg)
          `;
        }
      });
    </script>
  </body>
</html>